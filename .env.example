# ──────────────────────────────────────────
# LOCAL DEVELOPMENT (.env.local)
# ──────────────────────────────────────────

# Supabase / Neon PostgreSQL connection string
# Supabase: Settings → Database → Connection string → Transaction pooler
# Neon:     Dashboard → Connection Details → Pooled connection
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-output-of: openssl rand -hex 32"

# Cron job security token (used in Authorization: Bearer <token>)
CRON_SECRET="replace-with-output-of: openssl rand -hex 32"

# ──────────────────────────────────────────
# FACEBOOK OAUTH (for Connect with Facebook)
# ──────────────────────────────────────────
# 1. Go to https://developers.facebook.com → My Apps → Create App
# 2. Add "Facebook Login" product to your app
# 3. Settings → Basic → copy App ID and App Secret
# 4. Facebook Login → Settings → add Valid OAuth Redirect URIs:
#    https://your-domain.com/api/connect/facebook/callback
#    http://localhost:3000/api/connect/facebook/callback  (local dev)
# 5. Required permissions: pages_manage_posts, pages_show_list,
#    publish_to_groups, pages_read_engagement
FACEBOOK_APP_ID="1664539041642188"
FACEBOOK_APP_SECRET="2476dd5a77947494d9d94aa1c48b787d"

# ──────────────────────────────────────────
# LINE OAUTH (for Connect with LINE Login)
# ──────────────────────────────────────────
# 1. Go to https://developers.line.biz → Create a new provider
# 2. Create a new channel → Choose "LINE Login"
# 3. Basic Settings → copy Channel ID and Channel Secret
# 4. LINE Login tab → Callback URL:
#    https://your-domain.com/api/connect/line/callback
#    http://localhost:3000/api/connect/line/callback  (local dev)
# Note: For LINE Messaging API (bot posting), use manual token entry in the modal.
LINE_CHANNEL_ID="2009615595"
LINE_CHANNEL_SECRET="b0d441a3b11adf56ea66a0bb2d71aea7"

# ──────────────────────────────────────────
# VERCEL DASHBOARD — Environment Variables
# ──────────────────────────────────────────
# DATABASE_URL    → same PostgreSQL connection string above
# NEXTAUTH_URL    → https://your-project.vercel.app
# NEXTAUTH_SECRET → generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRON_SECRET     → generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FACEBOOK_APP_ID     → from Facebook Developers Console
# FACEBOOK_APP_SECRET → from Facebook Developers Console
# LINE_CHANNEL_ID     → from LINE Developers Console
# LINE_CHANNEL_SECRET → from LINE Developers Console
